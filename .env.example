CROWDSEC_LAPI_URL=http://127.0.0.1:8078
CROWDSEC_API_KEY=your-bouncer-api-key
CROWDSEC_MACHINE_ID=trapstack
CROWDSEC_MACHINE_PASSWORD=your-machine-password
CROWDSEC_CONF_DIR=/opt/crowdsec/conf
NPMPLUS_LOG_DIR=/opt/npmplus/nginx/logs

# AI Log Analysis (optional — set AI_PROVIDER to enable)
# AI_PROVIDER=anthropic          # "anthropic" or "openai" (OpenAI-compatible, incl. Ollama)
# AI_API_KEY=your-api-key
# AI_API_URL=                    # Override API endpoint (e.g. http://localhost:11434/v1 for Ollama)
# AI_MODEL=                      # Override model name
